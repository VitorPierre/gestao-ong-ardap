<% content_for :page_title, "Assinatura Eletrônica" %>

<div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
  <div>
    <h1 class="text-3xl font-black text-gray-900">Assinatura Eletrônica</h1>
    <p class="text-sm text-gray-500 mt-1">Conferência final e validação via SHA256 - <%= @document.title %></p>
  </div>
  <%= link_to "Cancelar Assinatura e Voltar", admin_document_path(@document), class: "text-gray-600 hover:text-gray-900 font-medium text-sm border px-3 py-2 rounded bg-white" %>
</div>

<div class="bg-gray-50 p-4 border border-gray-200 rounded-lg mb-8 shadow-sm flex items-start gap-4">
  <div class="text-yellow-500 text-2xl">⚠️</div>
  <div>
    <h3 class="font-bold text-gray-800">ATENÇÃO: Este documento se tornará Imutável</h3>
    <p class="text-sm text-gray-600 mt-1">
      Após a assinatura, o sistema aplicará uma trava algorítmica (Hash) ao conteúdo abaixo, anexando a informação do computador, horário do servidor e responsável. Não será possível editar ou excluir os termos presentes neste arquivo sob nenhuma hipótese.
    </p>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <div class="lg:col-span-2">
    <h3 class="text-lg font-bold mb-4 text-gray-900">Visão Geral do Contrato</h3>
    <div class="bg-white p-8 rounded-lg shadow-sm border border-gray-200 pointer-events-none opacity-90 grayscale-[0.2]">
      <div class="text-center border-b-2 border-gray-300 pb-4 mb-6">
         <h1 class="text-2xl font-bold text-gray-800">ARDAP - Associação de Resgate</h1>
         <p class="text-xs text-gray-500">Formato Protegido em Leitura</p>
      </div>
      <%= raw @document.content %>
    </div>
  </div>

  <div class="lg:col-span-1">
    <div class="bg-white p-6 rounded-lg shadow-sm border-t-4 border-yellow-400 border-x border-b">
      <h3 class="font-black text-gray-900 mb-4 uppercase tracking-wide">Credenciais de Assinatura</h3>
      
      <%= form_with model: [@document, @signature], url: admin_document_signatures_path(@document), local: true do |f| %>
        <% if @signature.errors.any? %>
          <div class="bg-red-50 text-red-700 px-3 py-2 rounded text-sm mb-4">
            <% @signature.errors.full_messages.each do |msg| %>
              <p><%= msg %></p>
            <% end %>
          </div>
        <% end %>

        <div class="mb-4">
          <%= f.label :signer_name, "Nome Completo do Signatário / Visto Por:", class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= f.text_field :signer_name, required: true, class: "w-full border-gray-300 rounded focus:ring-yellow-500 focus:border-yellow-500" %>
        </div>

        <div class="mb-6 bg-gray-50 border border-gray-200 p-3 rounded">
          <label class="flex items-start gap-3 cursor-pointer">
            <%= f.check_box :accepted_terms, { required: true, class: "mt-1 h-4 w-4 text-yellow-600 focus:ring-yellow-500 border-gray-300 rounded" }, "true", "false" %>
            <span class="text-sm text-gray-700 font-medium">Declaro que li e compreendi as informações do painel lateral. Ao prosseguir, reconheço a validade dos registros processados internamente (SHA256).</span>
          </label>
        </div>

        <%= f.submit "ASSINAR E FECHAR DOCUMENTO", class: "w-full bg-yellow-500 hover:bg-yellow-400 text-gray-900 font-black py-3 rounded shadow transition cursor-pointer" %>
      <% end %>
    </div>
    
  </div>
</div>
