<% content_for :page_title, "Câmera de Auditoria (Logs)" %>

<div class="mb-6 flex flex-col md:flex-row justify-between items-center gap-4">
  <div>
    <h1 class="text-3xl font-black text-gray-900">Histórico de Sistema</h1>
    <p class="text-sm text-gray-500 mt-1">Rastreio imutável de quem fez o que no sistema da ONG.</p>
  </div>
</div>

<div class="bg-gray-100 p-4 rounded-lg mb-6 border border-gray-200">
  <%= form_with url: admin_audit_logs_path, method: :get, class: "flex flex-wrap gap-4 items-end", skip_enforcing_utf8: true do |f| %>
    <div>
      <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest mb-1">Ação Específica</label>
      <%= f.text_field :action_filter, value: params[:action_filter], placeholder: "Ex: create, sign_in", class: "rounded border border-gray-300 text-sm py-2 px-3 focus:ring-yellow-500 focus:border-yellow-500" %>
    </div>
    <div>
      <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest mb-1">Tipo de Classe</label>
      <%= f.text_field :resource_type, value: params[:resource_type], placeholder: "Ex: Animal, Document", class: "rounded border border-gray-300 text-sm py-2 px-3 focus:ring-yellow-500 focus:border-yellow-500" %>
    </div>
    <div>
      <%= f.submit "Filtrar", class: "bg-gray-900 text-white font-bold py-2.5 px-5 rounded text-sm hover:bg-gray-800 cursor-pointer shadow-sm" %>
      <%= link_to "Limpar Filtros", admin_audit_logs_path, class: "ml-3 text-sm font-medium text-gray-600 hover:underline" %>
    </div>
  <% end %>
</div>

<div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden mb-8">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-5 py-4 text-left text-xs font-extrabold text-gray-700 uppercase tracking-wider">Horário Exato</th>
          <th class="px-5 py-4 text-left text-xs font-extrabold text-gray-700 uppercase tracking-wider">Agente Lógico</th>
          <th class="px-5 py-4 text-left text-xs font-extrabold text-gray-700 uppercase tracking-wider">Ação Engatilhada</th>
          <th class="px-5 py-4 text-left text-xs font-extrabold text-gray-700 uppercase tracking-wider">Alvo Objeto</th>
          <th class="px-5 py-4 text-left text-xs font-extrabold text-gray-700 uppercase tracking-wider">IP de Origem</th>
          <th class="px-5 py-4 text-left text-xs font-extrabold text-gray-700 uppercase tracking-wider">Rastro Payload</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @audit_logs.each do |log| %>
          <tr class="hover:bg-yellow-50 transition-colors">
            <td class="px-5 py-3 text-xs text-gray-600 whitespace-nowrap"><%= log.occurred_at.strftime("%d/%m %H:%M:%S") %></td>
            <td class="px-5 py-3 text-sm font-bold text-gray-900 uppercase">
              <%= log.user ? log.user.name : "Sistema/Forasteiro" %>
            </td>
            <td class="px-5 py-3 text-xs font-bold font-mono <%= log.action.include?('delete') || log.action.include?('cancel') || log.action.include?('fail') ? 'text-red-700 bg-red-100' : 'text-blue-800 bg-blue-100' %> px-2 py-1 rounded inline-block text-center mt-2.5 ml-2">
              <%= log.action %>
            </td>
            <td class="px-5 py-3 text-xs text-gray-700 font-medium">
              <% if log.auditable_type.present? %>
                <strong><%= log.auditable_type %> #<%= log.auditable_id %></strong>
              <% else %>
                —
              <% end %>
            </td>
            <td class="px-5 py-3 text-xs text-gray-500 font-mono"><%= log.ip_address %></td>
            <td class="px-5 py-3 text-xs text-gray-500 max-w-xs truncate" title="<%= log.payload.to_json %>">
              <%= log.payload.present? ? "Registrado (#{log.payload.keys.join(', ')})" : "—" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
