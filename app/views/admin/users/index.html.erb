<% content_for :page_title, "Gestão de Equipe (Usuários do Sistema)" %>

<div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
  <div>
    <h1 class="text-3xl font-black text-gray-900">Configurações de Usuários</h1>
    <p class="text-sm text-gray-500 mt-1">Gerencie quem tem acesso ao sistema administrativo da ONG e o nível de poder de cada um.</p>
  </div>
  <%= link_to "+ Cadastrar Novo Usuário", new_admin_user_path, class: "bg-gray-900 hover:bg-gray-800 text-white font-bold py-2.5 px-5 rounded shadow hover:shadow-md transition" %>
</div>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden mb-8">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Usuário e E-mail</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Nível Lógico (Perfil)</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Último Login</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @users.each do |user| %>
          <tr class="hover:bg-gray-50 <%= user.active? ? '' : 'opacity-60 saturate-50' %>">
            <td class="px-6 py-4">
              <p class="text-sm font-bold text-gray-900"><%= user.name %></p>
              <p class="text-xs text-gray-500"><%= user.email %></p>
            </td>
            <td class="px-6 py-4">
              <% badge_color = case user.role
                 when 'admin' then 'bg-purple-100 text-purple-800 border-purple-200'
                 when 'operator' then 'bg-blue-100 text-blue-800 border-blue-200'
                 else 'bg-gray-100 text-gray-800 border-gray-200'
                 end %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded border text-xs font-bold <%= badge_color %>">
                <%= user.role.upcase %>
              </span>
            </td>
            <td class="px-6 py-4">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium <%= user.active? ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                <%= user.active? ? "Ativo" : "Bloqueado" %>
              </span>
            </td>
            <td class="px-6 py-4 text-xs text-gray-500">
              <%= user.last_sign_in_at ? user.last_sign_in_at.strftime("%d/%m/%Y às %H:%M") : "Nunca acessou" %>
            </td>
            <td class="px-6 py-4 text-right text-sm">
              <%= link_to "Editar", edit_admin_user_path(user), class: "text-blue-600 hover:text-blue-900 font-medium mr-3" %>
              <% if user != current_user %>
                <%= button_to user.active? ? "Suspender Acesso" : "Reativar", toggle_active_admin_user_path(user), method: :patch, class: "#{user.active? ? 'text-red-600 hover:text-red-900' : 'text-green-600 hover:text-green-900'} font-bold", form: { class: "inline" } %>
              <% else %>
                <span class="text-gray-400 text-xs italic">Você</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
