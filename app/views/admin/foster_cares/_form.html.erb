<% input_class = "block w-full rounded-md border border-gray-300 px-3 py-2 mt-1 shadow-sm text-sm focus:border-yellow-500 focus:outline-none" %>
<% label_class = "block text-sm font-medium text-gray-700 mt-5" %>

<%= form_with(model: [:admin, foster_care], class: "bg-white p-6 rounded-lg shadow border border-gray-200") do |form| %>
  <% if foster_care.errors.any? %>
    <div class="bg-red-50 text-red-700 px-4 py-3 rounded-md mb-5 border-l-4 border-red-500">
      <p class="font-bold mb-1"><%= pluralize(foster_care.errors.count, "erro impediu", "erros impediram") %> o cadastro de ser salvo:</p>
      <ul class="list-disc ml-5 text-sm">
        <% foster_care.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6">
    <div>
      <%= form.label :person_id, "Tutor Temporário (Pessoa)", class: label_class %>
      <%= form.collection_select :person_id, Person.order(:name), :id, :name,
          { include_blank: "Selecione uma pessoa..." },
          class: input_class %>
    </div>
    <div>
      <%= form.label :animal_id, "Animal", class: label_class %>
      <%= form.collection_select :animal_id, Animal.order(:name), :id, :name,
          { include_blank: "Selecione um animal..." },
          class: input_class %>
    </div>
    <div>
      <%= form.label :start_date, "Data de Início", class: label_class %>
      <%= form.date_field :start_date, class: input_class %>
    </div>
    <div>
      <%= form.label :end_date, "Data de Término (prevista)", class: label_class %>
      <%= form.date_field :end_date, class: input_class %>
    </div>
    <div>
      <%= form.label :status, "Status", class: label_class %>
      <%= form.select :status,
          [["Ativo", "active"], ["Concluído", "completed"], ["Cancelado", "cancelled"]],
          { include_blank: "Selecione..." },
          class: input_class %>
    </div>
  </div>

  <div class="mt-5">
    <%= form.label :notes, "Observações", class: label_class %>
    <%= form.text_area :notes, rows: 4, class: input_class, placeholder: "Informações adicionais sobre o lar temporário..." %>
  </div>

  <div class="mt-6 flex items-center gap-4">
    <%= form.submit "Salvar Lar Temporário", class: "bg-yellow-500 hover:bg-yellow-400 text-gray-900 font-bold py-2.5 px-5 rounded-md shadow transition cursor-pointer" %>
    <%= link_to "Cancelar", admin_foster_cares_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
<% end %>
