<% input_class = "block w-full rounded-md border border-gray-300 px-3 py-2 mt-1 shadow-sm text-sm focus:border-yellow-500 focus:outline-none" %>
<% label_class = "block text-sm font-medium text-gray-700 mt-5" %>

<%= form_with(model: [:admin, animal], class: "bg-white p-6 rounded-lg shadow border border-gray-200") do |form| %>
  <% if animal.errors.any? %>
    <div class="bg-red-50 text-red-700 px-4 py-3 rounded-md mb-5 border-l-4 border-red-500">
      <p class="font-bold mb-1"><%= pluralize(animal.errors.count, "erro impediu", "erros impediram") %> o cadastro de ser salvo:</p>
      <ul class="list-disc ml-5 text-sm">
        <% animal.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6">
    <div>
      <%= form.label :name, "Nome do Animal", class: label_class %>
      <%= form.text_field :name, class: input_class, placeholder: "Ex: Rex" %>
    </div>
    <div>
      <%= form.label :species, "Espécie", class: label_class %>
      <%= form.select :species,
          Animal.species.keys.map { |k| [k.capitalize, k] },
          { include_blank: "Selecione..." },
          class: input_class %>
    </div>
    <div>
      <%= form.label :gender, "Sexo", class: label_class %>
      <%= form.select :gender,
          [["Macho", "male"], ["Fêmea", "female"], ["Indefinido", "unknown"]],
          { include_blank: "Selecione..." },
          class: input_class %>
    </div>
    <div>
      <%= form.label :size, "Porte", class: label_class %>
      <%= form.select :size,
          [["Pequeno", "small"], ["Médio", "medium"], ["Grande", "large"]],
          { include_blank: "Selecione..." },
          class: input_class %>
    </div>
    <div>
      <%= form.label :breed, "Raça", class: label_class %>
      <%= form.text_field :breed, class: input_class, placeholder: "Ex: SRD, Labrador..." %>
    </div>
    <div>
      <%= form.label :color, "Cor / Pelagem", class: label_class %>
      <%= form.text_field :color, class: input_class, placeholder: "Ex: Caramelo, Preto e branco..." %>
    </div>
    <div>
      <%= form.label :approximate_age, "Idade Aproximada", class: label_class %>
      <%= form.text_field :approximate_age, class: input_class, placeholder: "Ex: 2 anos, 6 meses..." %>
    </div>
    <div>
      <%= form.label :weight, "Peso (kg)", class: label_class %>
      <%= form.number_field :weight, step: 0.1, class: input_class, placeholder: "Ex: 5.2" %>
    </div>
    <div>
      <%= form.label :status, "Status", class: label_class %>
      <%= form.select :status,
          [["Disponível", "available"], ["Adotado", "adopted"], ["Lar Temporário", "in_foster_care"], ["Tratamento Médico", "medical_treatment"], ["Inativo", "inactive"]],
          { include_blank: "Selecione..." },
          class: input_class %>
    </div>
  </div>

  <div class="flex gap-8 mt-5">
    <div class="flex items-center gap-2">
      <%= form.check_box :neutered, class: "h-4 w-4 rounded border-gray-300 text-yellow-500" %>
      <%= form.label :neutered, "Castrado(a)", class: "text-sm font-medium text-gray-700" %>
    </div>
    <div class="flex items-center gap-2">
      <%= form.check_box :vaccinated, class: "h-4 w-4 rounded border-gray-300 text-yellow-500" %>
      <%= form.label :vaccinated, "Vacinado(a)", class: "text-sm font-medium text-gray-700" %>
    </div>
    <div class="flex items-center gap-2">
      <%= form.check_box :dewormed, class: "h-4 w-4 rounded border-gray-300 text-yellow-500" %>
      <%= form.label :dewormed, "Vermifugado(a)", class: "text-sm font-medium text-gray-700" %>
    </div>
  </div>

  <div class="mt-5">
    <%= form.label :notes, "Observações", class: label_class %>
    <%= form.text_area :notes, rows: 4, class: input_class, placeholder: "Comportamento, histórico, necessidades especiais..." %>
  </div>

  <div class="mt-6 flex items-center gap-4">
    <%= form.submit "Salvar Animal", class: "bg-yellow-500 hover:bg-yellow-400 text-gray-900 font-bold py-2.5 px-5 rounded-md shadow transition cursor-pointer" %>
    <%= link_to "Cancelar", admin_animals_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
<% end %>
