<% content_for :page_title, "Detalhes do Documento" %>

<div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
  <div>
    <h1 class="text-3xl font-black text-gray-900"><%= @document.title %></h1>
    <p class="text-sm text-gray-500 mt-1">Status: <%= @document.status.humanize %></p>
  </div>
  
  <div class="flex flex-wrap items-center gap-3">
    <%= link_to "← Voltar", admin_documents_path, class: "text-gray-600 hover:text-gray-900 font-medium text-sm" %>
    
    <% if @document.draft? %>
      <% if can_write? %><%= button_to "Marcar como Gerado (Pronto para Assinatura)", mark_generated_admin_document_path(@document), method: :patch, form: { class: "inline" }, class: "bg-blue-600 hover:bg-blue-500 text-white py-2 px-4 rounded font-medium shadow-sm cursor-pointer" %><% end %>
      <%= link_to "Editar Informações", edit_admin_document_path(@document), class: "bg-gray-100 hover:bg-gray-200 text-gray-800 py-2 px-4 rounded font-medium shadow-sm" %>
    <% end %>

    <% if @document.generated? %>
      <% if can_write? %><%= link_to "Assinar Documento", new_admin_document_signature_path(@document), class: "bg-yellow-500 hover:bg-yellow-400 text-gray-900 font-extrabold py-2 px-6 rounded shadow-sm" %><% end %>
      <%= link_to "Editar Informações", edit_admin_document_path(@document), class: "bg-white border border-gray-300 hover:bg-gray-50 text-gray-800 py-2 px-4 rounded font-medium shadow-sm" %>
    <% end %>

    <% if @document.content.present? %>
       <%= link_to "Baixar / Imprimir PDF", generate_pdf_admin_document_path(@document), data: { turbo: false }, class: "bg-gray-900 hover:bg-gray-800 text-white py-2 px-4 rounded font-medium shadow-sm" %>
    <% end %>

    <% unless @document.canceled? %>
      <% if can_write? %><%= button_to "Cancelar Documento", cancel_admin_document_path(@document), method: :patch, form: { data: { turbo_confirm: "Tem certeza que deseja inutilizar esse arquivo para sempre?" }, class: "inline" }, class: "text-red-600 hover:text-red-800 hover:bg-red-50 text-sm font-bold py-2 px-3 rounded border border-transparent hover:border-red-200 cursor-pointer" %><% end %>
    <% end %>
  </div>
</div>

<% if @document.signed? %>
  <div class="bg-green-50 border border-green-200 border-l-4 border-l-green-600 p-5 mb-8 rounded shadow-sm">
    <div class="flex items-start">
      <div class="flex-shrink-0 text-green-600 text-2xl pt-1">🔒</div>
      <div class="ml-4 flex-1">
        <h3 class="text-sm font-black text-green-900 uppercase tracking-widest mb-3 border-b-2 border-green-200 pb-2 inline-block">Documento Assinado Eletronicamente (Intranet ARDAP)</h3>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 text-sm text-green-800">
          <% if @document.document_signature.present? %>
            <div>
              <p class="mb-1"><strong class="font-bold">Signatário:</strong> <%= @document.document_signature.signer_name %></p>
              <p><strong class="font-bold">Data/Hora de Registro:</strong> <%= @document.document_signature.signed_at.strftime('%d/%m/%Y às %H:%M:%S') %></p>
            </div>
            <div>
              <p class="mb-1"><strong class="font-bold">Endereço Lógico (IP):</strong> <%= @document.document_signature.signer_ip %></p>
              <p><strong class="font-bold">Hash de Integridade (SHA256):</strong></p>
              <div class="font-mono text-xs bg-green-100 px-2 py-1 rounded inline-block border border-green-300 mt-1 truncate max-w-full"><%= @document.document_signature.content_hash %></div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% elsif @document.canceled? %>
  <div class="bg-red-50 border border-red-200 p-5 mb-8 rounded shadow-sm text-center">
    <div class="text-red-500 text-3xl mb-2">❌</div>
    <h3 class="text-sm font-black text-red-900 uppercase tracking-widest mb-1">Documento Cancelado</h3>
    <p class="text-xs text-red-700 font-medium">Este documento foi cancelado administrativamente e perdeu o valor comprobatório.</p>
  </div>
<% end %>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-8">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
       <p class="text-sm text-gray-500 font-bold uppercase tracking-wider mb-1">Categoria</p>
       <p class="text-gray-900"><%= @document.category&.humanize || "Sem Categoria" %></p>
    </div>
    <div>
       <p class="text-sm text-gray-500 font-bold uppercase tracking-wider mb-1">Tipo Oficial</p>
       <p class="text-gray-900"><%= @document.document_type&.humanize || "Anexo Externo" %></p>
    </div>
    <div class="md:col-span-2">
       <p class="text-sm text-gray-500 font-bold uppercase tracking-wider mb-1">Descrição</p>
       <p class="text-gray-900 whitespace-pre-wrap"><%= @document.description.presence || "—" %></p>
    </div>
    <% if @document.file.attached? %>
      <div class="md:col-span-2 mt-4 p-4 bg-gray-50 border rounded flex items-center justify-between">
         <span class="text-sm font-medium text-gray-800">📎 <%= @document.file.filename %></span>
         <%= link_to "Baixar Anexo Original", rails_blob_path(@document.file, disposition: "attachment"), class: "text-blue-600 hover:underline text-sm font-bold" %>
      </div>
    <% end %>
  </div>
</div>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-8">
  <h3 class="text-lg leading-6 font-medium text-gray-900 border-b pb-2 mb-4">Usuário Criador</h3>
  <% if @document.creator_user.present? %>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <div>
        <p class="text-xs text-gray-500 font-bold uppercase tracking-wider mb-1">Nome</p>
        <p class="text-sm text-gray-900"><%= @document.creator_user.name %></p>
      </div>
      <div>
        <p class="text-xs text-gray-500 font-bold uppercase tracking-wider mb-1">E-mail</p>
        <p class="text-sm text-gray-900"><%= @document.creator_user.email %></p>
      </div>
      <div>
        <p class="text-xs text-gray-500 font-bold uppercase tracking-wider mb-1">Perfil</p>
        <p class="text-sm text-gray-900"><%= @document.creator_user.role&.humanize %></p>
      </div>
      <div>
        <p class="text-xs text-gray-500 font-bold uppercase tracking-wider mb-1">Data de Criação</p>
        <p class="text-sm text-gray-900"><%= @document.created_at.strftime('%d/%m/%Y às %H:%M') %></p>
      </div>
    </div>
  <% else %>
    <p class="text-sm text-gray-500 italic">Informação não disponível (Documento Legado).</p>
  <% end %>
</div>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-8">
  <h3 class="text-lg leading-6 font-medium text-gray-900 border-b pb-2 mb-4">Participantes Externos Envolvidos</h3>
  <% if @document.document_participants.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Papel</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nome Completo</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Documento</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Contato</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @document.document_participants.each do |participant| %>
            <tr>
              <td class="px-4 py-3 whitespace-nowrap text-sm font-bold text-gray-900">
                <%= participant.role_in_document&.humanize || 'Não especificado' %>
              </td>
              <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-700">
                <%= participant.full_name %>
                <span class="block text-xs text-gray-400"><%= participant.external_type&.humanize %></span>
              </td>
              <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-700">
                <%= participant.document_kind&.upcase %>: <%= participant.document_number.presence || '—' %>
              </td>
              <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-700">
                <div class="flex flex-col">
                  <% if participant.phone.present? %><span>📞 <%= participant.phone %></span><% end %>
                  <% if participant.email.present? %><span>✉️ <%= participant.email %></span><% end %>
                  <% if participant.phone.blank? && participant.email.blank? %><span class="text-gray-400">—</span><% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-sm text-gray-500 italic">Nenhum participante externo registrado.</p>
  <% end %>
</div>


<% if @document.content.present? %>
  <h3 class="text-xl font-bold mb-4">Pré-visualização do Documento Impresso</h3>
  <div class="bg-white p-8 rounded-lg shadow-sm border border-gray-200" style="max-width: 800px; margin: 0 auto;">
     <div class="text-center border-b-2 border-yellow-400 pb-4 mb-6">
       <h1 class="text-2xl font-bold text-gray-900">ARDAP - Associação de Resgate</h1>
       <p class="text-xs text-gray-500">Documento Oficial | Pré-visualização</p>
     </div>
     <div class="pdf-content text-gray-800">
       <%= raw @document.content %>
     </div>
  </div>
<% end %>
