<%= form_with(model: [:admin, document], class: "bg-white p-6 rounded-lg shadow-sm border border-gray-200") do |form| %>
  <% if document.errors.any? %>
    <div class="bg-red-50 text-red-700 px-4 py-3 rounded-md mb-5 border-l-4 border-red-500">
      <ul class="list-disc ml-5 text-sm">
        <% document.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% input_class = "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-gray-500 focus:ring-gray-500 sm:text-sm px-3 py-2 border" %>

  <%= form.hidden_field :linked_type %>
  <%= form.hidden_field :linked_id %>

  <div class="space-y-8">
    <!-- BLOCO 1 - DADOS DO DOCUMENTO -->
    <div>
      <h3 class="text-lg leading-6 font-medium text-gray-900 border-b pb-2 mb-4">1. Dados do Documento</h3>
      <div class="space-y-4">
        <div>
          <%= form.label :title, "Título do Documento", class: "block text-sm font-medium text-gray-700" %>
          <%= form.text_field :title, class: input_class %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= form.label :category, "Categoria do Processo", class: "block text-sm font-medium text-gray-700" %>
            <%= form.select :category, Document.categories.keys.map { |c| [c.humanize, c] }, { include_blank: "Sem Categoria" }, class: input_class %>
          </div>

          <div>
            <%= form.label :document_type, "Tipo de Documento Oficial", class: "block text-sm font-medium text-gray-700" %>
            <%= form.select :document_type, Document.document_types.keys.map { |t| [t.humanize, t] }, { include_blank: "Outro/Upload Livre" }, class: input_class %>
          </div>
        </div>

        <div>
          <%= form.label :description, "Descrição Interna", class: "block text-sm font-medium text-gray-700" %>
          <%= form.text_area :description, rows: 3, class: input_class %>
        </div>

        <% if document.draft? || document.new_record? %>
          <% if document.document_type.present? %>
            <% begin %>
              <div class="mt-4 p-4 border border-yellow-200 bg-yellow-50 rounded">
                <h4 class="font-bold text-sm text-yellow-800 mb-3">Campos Específicos do Documento</h4>
                <%= render "admin/documents/forms/#{document.document_type}", form: form %>
              </div>
            <% rescue ActionView::MissingTemplate %>
              <!-- No specific template for this document_type -->
            <% end %>
          <% end %>

          <div class="bg-gray-50 p-4 border rounded mt-4">
            <h4 class="font-bold text-sm text-gray-700 mb-2">Upload de Arquivo Físico (Anexo Legado)</h4>
            <p class="text-xs text-gray-500 mb-3">Se este for apenas um anexo externo (receita de fora, documento escaneado), separe o arquivo aqui. Em breve, a geração será automática para documentos oficiais da ONG.</p>
            <%= form.file_field :file, class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-gray-900 file:text-white hover:file:bg-gray-800" %>
          </div>
        <% else %>
          <div class="bg-yellow-50 p-4 border border-yellow-200 rounded mt-4">
            <p class="text-sm text-yellow-800">Este documento não está mais em rascunho e suas definições estruturais estão travadas para proteger o processo de assinatura.</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- BLOCO 2 - USUÁRIO CRIADOR -->
    <div>
      <h3 class="text-lg leading-6 font-medium text-gray-900 border-b pb-2 mb-4">2. Usuário Criador</h3>
      <div class="bg-gray-50 p-4 rounded border border-gray-200 text-sm text-gray-700">
        <p class="mb-2"><strong>Aviso:</strong> A criação deste documento está atrelada ao seu usuário autenticado de forma rastreável e não pode ser modificada.</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-3">
          <div>
            <span class="block text-xs font-semibold text-gray-500 uppercase tracking-wider">Nome</span>
            <span><%= document.new_record? ? current_user.name : document.creator_user&.name %></span>
          </div>
          <div>
            <span class="block text-xs font-semibold text-gray-500 uppercase tracking-wider">E-mail</span>
            <span><%= document.new_record? ? current_user.email : document.creator_user&.email %></span>
          </div>
          <div>
            <span class="block text-xs font-semibold text-gray-500 uppercase tracking-wider">Perfil</span>
            <span><%= document.new_record? ? current_user.role.humanize : document.creator_user&.role&.humanize %></span>
          </div>
        </div>
      </div>
    </div>

    <!-- BLOCO 3 - PESSOAS EXTERNAS ENVOLVIDAS -->
    <div data-controller="nested-form">
      <h3 class="text-lg leading-6 font-medium text-gray-900 border-b pb-2 mb-4">3. Participantes Externos</h3>
      <p class="text-sm text-gray-500 mb-4">Adicione pelo menos um participante externo envolvido neste documento.</p>
      
      <template data-nested-form-target="template">
        <%= form.fields_for :document_participants, DocumentParticipant.new, child_index: 'NEW_RECORD' do |participant_fields| %>
          <%= render "admin/documents/document_participant_fields", f: participant_fields, document: document %>
        <% end %>
      </template>

      <div data-nested-form-target="links" class="space-y-4">
        <%= form.fields_for :document_participants do |participant_fields| %>
          <%= render "admin/documents/document_participant_fields", f: participant_fields, document: document %>
        <% end %>
      </div>

      <% unless document.signed? || document.is_locked? %>
        <div class="mt-4">
          <button type="button" data-action="nested-form#add_association" class="inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">
            + Adicionar Novo Participante
          </button>
        </div>
      <% else %>
        <div class="mt-4 bg-yellow-50 p-3 rounded border border-yellow-200">
          <p class="text-sm text-yellow-800">Participantes bloqueados para edição pois o documento já foi assinado/trancado.</p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-8 pt-5 border-t border-gray-200 flex justify-end gap-3">
    <%= link_to "Cancelar", admin_documents_path, class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    <% unless document.signed? || document.is_locked? %>
      <%= form.submit "Salvar Documento", class: "bg-gray-900 py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900 cursor-pointer" %>
    <% end %>
  </div>
<% end %>
