<div id="<%= dom_id document %>" class="w-full sm:w-auto my-5 space-y-5 bg-white shadow p-6 rounded-lg mb-6">
  <h2 class="font-bold text-2xl text-gray-800 mb-2"><%= document.title %></h2>
  <p class="text-gray-600 mb-5"><%= document.description %></p>

  <% if document.file.attached? %>
    <div class="p-4 border rounded-md bg-gray-50 flex items-center justify-between">
      <span class="font-medium text-gray-700 truncate mr-4"><%= document.file.filename %></span>
      <%= link_to "Baixar Anexo", rails_blob_path(document.file, disposition: "attachment"), class: "text-blue-600 hover:text-blue-800 font-medium whitespace-nowrap" %>
    </div>
  <% else %>
    <p class="text-gray-500 italic">Nenhum arquivo anexado.</p>
  <% end %>
</div>
