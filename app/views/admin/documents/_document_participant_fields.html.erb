<% disabled = document.present? && (document.signed? || document.is_locked?) %>
<div class="nested-fields bg-white border border-gray-200 shadow-sm p-4 rounded-md relative mb-4">
  <%= f.hidden_field :_destroy %>
  
  <% unless disabled %>
    <div class="absolute top-2 right-2">
      <button type="button" data-action="nested-form#remove_association" class="text-red-500 hover:text-red-700 text-sm font-medium">
        Remover
      </button>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="md:col-span-2">
      <%= f.label :full_name, "Nome Completo", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :full_name, disabled: disabled, maxlength: 150, autocomplete: "name", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-gray-500 focus:ring-gray-500 sm:text-sm px-3 py-2 border #{'bg-gray-100 text-gray-500 cursor-not-allowed' if disabled}" %>
      <%= inline_errors_for(f.object, :full_name) %>
    </div>

    <div>
      <%= f.label :role_in_document, "Papel no Documento", class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :role_in_document, DocumentParticipant.role_in_documents.keys.map { |r| [r.humanize, r] }, { include_blank: "Selecione..." }, disabled: disabled, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-gray-500 focus:ring-gray-500 sm:text-sm px-3 py-2 border #{'bg-gray-100 text-gray-500 cursor-not-allowed' if disabled}" %>
      <%= inline_errors_for(f.object, :role_in_document) %>
    </div>

    <div>
      <%= f.label :external_type, "Tipo de Pessoa", class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :external_type, DocumentParticipant.external_types.keys.map { |e| [e.humanize, e] }, {}, disabled: disabled, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-gray-500 focus:ring-gray-500 sm:text-sm px-3 py-2 border #{'bg-gray-100 text-gray-500 cursor-not-allowed' if disabled}" %>
      <%= inline_errors_for(f.object, :external_type) %>
    </div>

    <div>
      <%= f.label :document_kind, "Tipo de Documento", class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :document_kind, DocumentParticipant.document_kinds.keys.map { |k| [k.humanize, k] }, { include_blank: "Selecione..." }, disabled: disabled, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-gray-500 focus:ring-gray-500 sm:text-sm px-3 py-2 border #{'bg-gray-100 text-gray-500 cursor-not-allowed' if disabled}" %>
      <%= inline_errors_for(f.object, :document_kind) %>
    </div>

    <div>
      <%= f.label :document_number, "Número do Documento", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :document_number, disabled: disabled, maxlength: 20, autocomplete: "off", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-gray-500 focus:ring-gray-500 sm:text-sm px-3 py-2 border #{'bg-gray-100 text-gray-500 cursor-not-allowed' if disabled}" %>
      <%= inline_errors_for(f.object, :document_number) %>
    </div>

    <div>
      <%= f.label :phone, "Telefone", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :phone, disabled: disabled, maxlength: 20, inputmode: "numeric", autocomplete: "tel", data: { controller: "mask", mask_type_value: "phone" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-gray-500 focus:ring-gray-500 sm:text-sm px-3 py-2 border #{'bg-gray-100 text-gray-500 cursor-not-allowed' if disabled}" %>
      <%= inline_errors_for(f.object, :phone) %>
    </div>

    <div>
      <%= f.label :email, "E-mail", class: "block text-sm font-medium text-gray-700" %>
      <%= f.email_field :email, disabled: disabled, maxlength: 254, autocomplete: "email", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-gray-500 focus:ring-gray-500 sm:text-sm px-3 py-2 border #{'bg-gray-100 text-gray-500 cursor-not-allowed' if disabled}" %>
      <%= inline_errors_for(f.object, :email) %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :address, "Endereço Completo", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :address, disabled: disabled, maxlength: 255, autocomplete: "street-address", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-gray-500 focus:ring-gray-500 sm:text-sm px-3 py-2 border #{'bg-gray-100 text-gray-500 cursor-not-allowed' if disabled}" %>
      <%= inline_errors_for(f.object, :address) %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :notes, "Observações (Opcional)", class: "block text-sm font-medium text-gray-700" %>
      <div data-controller="character-counter">
        <%= f.text_area :notes, rows: 2, disabled: disabled, maxlength: 1000, data: { character_counter_target: "input" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-gray-500 focus:ring-gray-500 sm:text-sm px-3 py-2 border #{'bg-gray-100 text-gray-500 cursor-not-allowed' if disabled}" %>
        <div data-character-counter-target="counter" class="text-xs text-right mt-1"></div>
      </div>
      <%= inline_errors_for(f.object, :notes) %>
    </div>
  </div>
</div>
