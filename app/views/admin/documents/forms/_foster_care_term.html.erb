<div class="space-y-4 border-t border-gray-200 mt-6 pt-6">
  <h4 class="font-bold text-gray-800 text-lg uppercase mb-4 tracking-wider"><%= "Dados do Documento: TERMO DE TUTELA E LAR TEMPORÁRIO" %></h4>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="">
      <label class="block text-sm font-semibold text-gray-700">ID do Lar</label>
      <input type="text" name="document_data[foster_care_id]" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-yellow-500 focus:ring-yellow-500 sm:text-sm px-3 py-2 border" />
    </div>
    <div class="">
      <label class="block text-sm font-semibold text-gray-700">Nome da Tutela</label>
      <input type="text" name="document_data[foster_name]" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-yellow-500 focus:ring-yellow-500 sm:text-sm px-3 py-2 border" />
    </div>
    <div class="">
      <label class="block text-sm font-semibold text-gray-700">CPF Tutor</label>
      <input type="text" name="document_data[foster_cpf]" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-yellow-500 focus:ring-yellow-500 sm:text-sm px-3 py-2 border" />
    </div>
    <div class="">
      <label class="block text-sm font-semibold text-gray-700">Nome Animal</label>
      <input type="text" name="document_data[animal_name]" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-yellow-500 focus:ring-yellow-500 sm:text-sm px-3 py-2 border" />
    </div>
    <div class="">
      <label class="block text-sm font-semibold text-gray-700">Data Início</label>
      <input type="date" name="document_data[start_date]" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-yellow-500 focus:ring-yellow-500 sm:text-sm px-3 py-2 border" />
    </div>
    <div class="">
      <label class="block text-sm font-semibold text-gray-700">Data Estimada Fim</label>
      <input type="date" name="document_data[estimated_end_date]" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-yellow-500 focus:ring-yellow-500 sm:text-sm px-3 py-2 border" />
    </div>
    <div class="md:col-span-2">
      <label class="block text-sm font-semibold text-gray-700">Responsabilidades</label>
      <textarea name="document_data[responsibilities_accepted]" rows="4" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-yellow-500 focus:ring-yellow-500 sm:text-sm px-3 py-2 border"></textarea>
    </div>
    <div class="md:col-span-2">
      <label class="block text-sm font-semibold text-gray-700">Cuidados Especias</label>
      <textarea name="document_data[special_care_instructions]" rows="4" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-yellow-500 focus:ring-yellow-500 sm:text-sm px-3 py-2 border"></textarea>
    </div>
  </div>
</div>
