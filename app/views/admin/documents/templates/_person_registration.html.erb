    <div style="width: 48%; text-align: center;">
      <p style="border-top: 1px solid #000; padding-top: 5px;">Interveniente/Outorgado<br><span style="font-size: 12px">Assinatura no Verso ou Digital</span></p>
    </div>
  </div>
</div>
