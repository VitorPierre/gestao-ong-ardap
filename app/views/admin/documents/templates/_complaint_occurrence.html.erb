<div style="font-family: Arial, sans-serif; background: #fff; padding: 20px;">
  <h2 style="text-align: center; font-weight: bold; font-size: 20px; border-bottom: 2px solid #000; padding-bottom: 10px; margin-bottom: 30px;">
    TERMO REGISTRAL DE OCORRÊNCIA E AUTUAÇÃO
  </h2>
  <div style="line-height: 1.8; font-size: 14px;">
    <p><strong>DEN ID:</strong> <%= data[:"complaint_id"] %></p>
    <p><strong>Data Flagrante:</strong> <%= data[:"occurrence_date"] %></p>
    <p><strong>Onde? Local Extenso:</strong> <%= data[:"location_description"] %></p>
    <p><strong>Partes Qualificadas:</strong> <%= data[:"involved_parties"] %></p>
    <p><strong>Sinopse do Inquérito:</strong> <%= data[:"description_of_facts"] %></p>
    <p><strong>Medidas Cautelares Aplicadas:</strong> <%= data[:"measures_taken"] %></p>
  </div>
  
  <div style="margin-top: 100px; display: flex; justify-content: space-between; border-top: 1px dashed #ccc; padding-top: 20px;">
    <div style="width: 48%; text-align: center;">
      <p style="border-top: 1px solid #000; padding-top: 5px;">Atestador ARDAP<br><span style="font-size: 12px">Documento Digital</span></p>
    </div>
    <div style="width: 48%; text-align: center;">
      <p style="border-top: 1px solid #000; padding-top: 5px;">Interveniente/Outorgado<br><span style="font-size: 12px">Assinatura no Verso ou Digital</span></p>
    </div>
  </div>
</div>
