<div style="font-family: Arial, sans-serif; background: #fff; padding: 20px;">
  <h2 style="text-align: center; font-weight: bold; font-size: 20px; border-bottom: 2px solid #000; padding-bottom: 10px; margin-bottom: 30px;">
    QUESTIONÁRIO DE PERFIL DO ADOTANTE
  </h2>
  <div style="line-height: 1.8; font-size: 14px;">
    <p><strong>ID da Pessoa:</strong> <%= data[:"person_id"] %></p>
    <p><strong>Mora em (Casa/Apto):</strong> <%= data[:"lives_in_house_or_apartment"] %></p>
    <p><strong>Possui Quintal?:</strong> <%= data[:"has_yard"] %></p>
    <p><strong>Animais Anteriores?:</strong> <%= data[:"has_other_animals"] %></p>
    <p><strong>Detalhes Animais:</strong> <%= data[:"animal_details"] %></p>
    <p><strong>Nº Membros Familia:</strong> <%= data[:"family_members_count"] %></p>
    <p><strong>Idade Crianças:</strong> <%= data[:"children_ages"] %></p>
    <p><strong>Trabalha de casa?:</strong> <%= data[:"works_from_home"] %></p>
    <p><strong>Horas fora por dia:</strong> <%= data[:"hours_away_per_day"] %></p>
    <p><strong>Experiência prévia?:</strong> <%= data[:"previous_pet_experience"] %></p>
    <p><strong>Motivo da Adoção:</strong> <%= data[:"reason_for_adoption"] %></p>
    <p><strong>Contato Res.:</strong> <%= data[:"emergency_contact_name"] %></p>
    <p><strong>Telefone Contato:</strong> <%= data[:"emergency_contact_phone"] %></p>
  </div>
  
  <div style="margin-top: 100px; display: flex; justify-content: space-between; border-top: 1px dashed #ccc; padding-top: 20px;">
    <div style="width: 48%; text-align: center;">
      <p style="border-top: 1px solid #000; padding-top: 5px;">Atestador ARDAP<br><span style="font-size: 12px">Documento Digital</span></p>
    </div>
    <div style="width: 48%; text-align: center;">
      <p style="border-top: 1px solid #000; padding-top: 5px;">Interveniente/Outorgado<br><span style="font-size: 12px">Assinatura no Verso ou Digital</span></p>
    </div>
  </div>
</div>
