<% content_for :page_title, "Doações" %>

<div class="flex flex-col md:flex-row justify-between md:items-center gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-black text-gray-900">Doações e Contribuições</h1>
    <p class="text-sm text-gray-500 mt-1">Acervo global de recebíveis e insumos</p>
  </div>
  <%= link_to "+ Adicionar Doação", new_admin_donation_path, class: "bg-green-600 hover:bg-green-500 text-white font-bold py-2.5 px-5 rounded-md shadow transition" %>
</div>

<div class="bg-gray-50 p-4 rounded-lg mb-6 border border-gray-200">
  <%= form_with url: admin_donations_path, method: :get, local: true, class: "flex items-end gap-3 flex-wrap" do |f| %>
    <div>
      <%= f.label :type, "Tipo", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :type, Donation.donation_types.keys.map { |t| [t.humanize, t] }, { include_blank: "Todos", selected: params[:type] }, class: "rounded border-gray-300 shadow-sm py-2 px-3 text-sm min-w-[140px]" %>
    </div>
    <div>
      <%= f.label :status, "Status", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :status, Donation.statuses.keys.map { |s| [s.humanize, s] }, { include_blank: "Todos", selected: params[:status] }, class: "rounded border-gray-300 shadow-sm py-2 px-3 text-sm min-w-[140px]" %>
    </div>
    <div>
      <%= f.label :period, "Período", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :period, [["Este Mês", "this_month"]], { include_blank: "Sempre", selected: params[:period] }, class: "rounded border-gray-300 shadow-sm py-2 px-3 text-sm min-w-[140px]" %>
    </div>
    <div class="flex gap-2">
      <%= f.submit "Aplicar", class: "bg-gray-800 hover:bg-gray-900 text-white font-medium py-2 px-4 rounded shadow-sm text-sm cursor-pointer" %>
      <%= link_to "Limpar", admin_donations_path, class: "bg-white hover:bg-gray-50 text-gray-700 font-medium py-2 px-4 rounded border border-gray-300 shadow-sm text-sm" %>
    </div>
  <% end %>
</div>

<% if @donations.any? %>
  <div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Data</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Origem/Doador</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Tipo</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Valor/Descrição</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Status</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @donations.each do |d| %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 text-sm text-gray-500"><%= l(d.donated_at) rescue d.donated_at %></td>
              <td class="px-4 py-3 text-sm font-bold text-gray-900">
                <% if d.partner_id.present? %>
                  <span class="inline-block text-[10px] bg-purple-100 text-purple-800 px-1.5 py-0.5 rounded font-mono mr-1">PJ</span>
                  <%= link_to d.partner.name, admin_partner_path(d.partner), class: "hover:underline text-purple-700" %>
                <% elsif d.person_id.present? %>
                  <span class="inline-block text-[10px] bg-blue-100 text-blue-800 px-1.5 py-0.5 rounded font-mono mr-1">PF</span>
                  <%= link_to d.person.name, admin_person_path(d.person), class: "hover:underline text-blue-700" %>
                <% else %>
                  <span class="text-gray-500 italic">Doador Anônimo</span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-xs">
                <% bg_type = d.financial? ? 'bg-green-100 text-green-800 border-green-200' : 'bg-orange-100 text-orange-800 border-orange-200' %>
                <span class="inline-flex px-2 py-0.5 rounded font-bold border <%= bg_type %>"><%= d.donation_type.humanize %></span>
                <% if d.recurrent? %>
                  <span title="Recorrente" class="ml-1 inline-block text-blue-500 mx-auto">↻</span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-sm font-medium text-gray-900">
                <% if d.financial? %>
                  <%= number_to_currency(d.amount, unit: "R$", separator: ",", delimiter: ".") %>
                <% else %>
                  <span class="text-gray-600 font-normal truncate inline-block max-w-[200px]" title="<%= d.description %>"><%= d.description %></span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-sm">
                <% dot_color = d.confirmed? ? 'bg-green-400' : (d.canceled? ? 'bg-red-400' : 'bg-yellow-400') %>
                <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full <%= dot_color %>"></span><%= d.status.humanize %></span>
              </td>
              <td class="px-4 py-3 text-right text-sm">
                <%= link_to "Recibo / Editar", edit_admin_donation_path(d), class: "text-blue-600 hover:underline" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <div class="bg-white rounded-lg border border-dashed border-gray-300 p-12 text-center">
    <p class="text-gray-500 text-lg">Nenhuma doação atende aos critérios atuais.</p>
  </div>
<% end %>
