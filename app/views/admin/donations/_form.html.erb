<% input_class = "block w-full rounded-md border border-gray-300 px-3 py-2 mt-1 shadow-sm text-sm focus:border-green-500 focus:outline-none" %>
<% label_class = "block text-sm font-medium text-gray-700 mt-4" %>

<%= form_with(model: [:admin, donation], class: "bg-white p-6 rounded-lg shadow border border-gray-200") do |form| %>
  <% if donation.errors.any? %>
    <div class="bg-red-50 text-red-700 px-4 py-3 rounded-md mb-5 border-l-4 border-red-500">
      <ul class="list-disc ml-5 text-sm">
        <% donation.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-2">
    
    <div class="md:col-span-2 border-b pb-2 mb-2 flex items-center justify-between">
      <h4 class="font-bold text-gray-800 text-sm">Vínculo Origem (Opcional)</h4>
      <span class="text-xs text-gray-500">Selecione apenas 1 (ou nenhum para Anônimo)</span>
    </div>

    <div>
      <%= form.label :person_id, "Pessoa Física", class: label_class %>
      <%= form.collection_select :person_id, Person.order(:name), :id, :name, { include_blank: "Nenhum / Anônimo" }, class: input_class %>
    </div>
    
    <div>
      <%= form.label :partner_id, "Instituição / Parceiro Oculto", class: label_class %>
      <%= form.collection_select :partner_id, Partner.order(:name), :id, :name, { include_blank: "Nenhuma" }, class: input_class %>
    </div>

    <div class="md:col-span-2 border-b pb-2 mt-4 mb-2">
      <h4 class="font-bold text-gray-800 text-sm">Aporte Principal</h4>
    </div>

    <div>
      <%= form.label :donated_at, "Data do Recebimento", class: label_class %>
      <%= form.date_field :donated_at, class: input_class %>
    </div>
    <div>
      <%= form.label :donation_type, "Natureza", class: label_class %>
      <%= form.select :donation_type, Donation.donation_types.keys.map { |t| [t.humanize, t] }, {}, class: input_class, id: "donation_type_selector" %>
    </div>

    <div id="financial_block" class="md:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-x-6 bg-green-50 p-4 rounded mt-4 border border-green-100">
      <div>
        <%= form.label :amount, "Valor Financeiro (R$)", class: "block text-sm font-medium text-green-900" %>
        <%= form.number_field :amount, step: "0.01", class: input_class %>
      </div>
      <div>
        <%= form.label :payment_method, "Meio de Pagamento", class: "block text-sm font-medium text-green-900" %>
        <%= form.select :payment_method, Donation.payment_methods.keys.map { |m| [m.humanize, m] }, {}, class: input_class %>
      </div>
    </div>

    <div id="supplies_block" class="md:col-span-2 bg-orange-50 p-4 rounded mt-4 border border-orange-100 hidden">
      <%= form.label :description, "Descrição dos Insumos (Ex: 10kg Ração, Cobertores)", class: "block text-sm font-medium text-orange-900" %>
      <%= form.text_area :description, rows: 2, class: input_class %>
    </div>

    <div class="md:col-span-2 border-b pb-2 mt-4 mb-2">
      <h4 class="font-bold text-gray-800 text-sm">Configuração</h4>
    </div>

    <div>
      <%= form.label :status, "Status Atual", class: label_class %>
      <%= form.select :status, Donation.statuses.keys.map { |s| [s.humanize, s] }, {}, class: input_class %>
    </div>
    
    <div>
      <%= form.label :receipt_number, "Nº do Recibo ou Transação", class: label_class %>
      <%= form.text_field :receipt_number, class: input_class %>
    </div>

    <div class="md:col-span-2 flex items-center bg-gray-50 p-4 mt-2 rounded border">
      <%= form.check_box :recurrent, id: "recurrent_checkbox", class: "h-4 w-4 text-green-600 focus:ring-green-500 border-gray-300 rounded" %>
      <%= form.label :recurrent, "É uma Doação Recorrente (Incidência Contínua)?", class: "ml-2 block text-sm text-gray-900 cursor-pointer" %>
      
      <div id="recurrence_interval_wrapper" class="ml-6 hidden">
        <%= form.select :recurrence_interval, Donation.recurrence_intervals.keys.map { |i| [i.humanize, i] }, { include_blank: "Intervalo..." }, class: "rounded border-gray-300 shadow-sm py-1 px-2 text-sm" %>
      </div>
    </div>

    <div class="md:col-span-2">
      <%= form.label :notes, "Notas Operacionais", class: label_class %>
      <%= form.text_area :notes, rows: 2, class: input_class %>
    </div>
  </div>

  <div class="mt-8 flex items-center gap-4 border-t pt-5">
    <%= form.submit "Salvar Doação", class: "bg-green-600 hover:bg-green-500 text-white font-bold py-2.5 px-6 rounded-md shadow transition cursor-pointer" %>
    <%= link_to "Cancelar", admin_donations_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
<% end %>

<script>
  function setupDonationForm() {
    const typeSelector = document.getElementById("donation_type_selector");
    const finBlock = document.getElementById("financial_block");
    const supBlock = document.getElementById("supplies_block");
    
    const recCheckbox = document.getElementById("recurrent_checkbox");
    const recInterval = document.getElementById("recurrence_interval_wrapper");

    function toggleTypes() {
      if(typeSelector && typeSelector.value === "supplies") {
        finBlock.style.display = "none";
        supBlock.style.display = "block";
      } else {
        finBlock.style.display = "grid";
        supBlock.style.display = "none";
      }
    }

    function toggleRecurrence() {
      if(recCheckbox && recCheckbox.checked) {
        recInterval.style.display = "block";
      } else if (recInterval) {
        recInterval.style.display = "none";
      }
    }

    if(typeSelector) typeSelector.addEventListener("change", toggleTypes);
    if(recCheckbox) recCheckbox.addEventListener("change", toggleRecurrence);
    
    toggleTypes();
    toggleRecurrence();
  }

  document.addEventListener("turbo:load", setupDonationForm);
  document.addEventListener("DOMContentLoaded", setupDonationForm);
</script>
