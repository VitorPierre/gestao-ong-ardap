<% content_for :title, "Volunteers" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Volunteers</h1>
    <%= link_to "New volunteer", new_admin_volunteer_path, class: "rounded-md px-3.5 py-2.5 bg-yellow-500 hover:bg-yellow-400 text-gray-900 shadow-sm transition hover:-translate-y-0.5 block font-medium" %>
  </div>

  <div id="volunteers" class="min-w-full divide-y divide-gray-200 space-y-5">
    <% if @volunteers.any? %>
      <% @volunteers.each do |volunteer| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <%= render volunteer %>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
            <%= link_to "Show", [:admin, volunteer], class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
            <%= link_to "Edit", edit_admin_volunteer_path(volunteer), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
            <% if can_write? %>
  <%= button_to "Destroy", [:admin, volunteer], method: :delete, class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
<% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="bg-white rounded-lg border border-dashed border-gray-300 p-10 text-center my-8">
        <p class="text-gray-500 text-lg">Nenhum registro encontrado.</p>
      </div>
    <% end %>
  </div>
</div>
