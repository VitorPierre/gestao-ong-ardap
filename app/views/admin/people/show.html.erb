<% content_for :title, "Showing person" %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl">Showing person</h1>

  <%= render @person %>

  <div class="mt-8 mb-4 border-t pt-6">
    <h3 class="text-2xl font-bold mb-4">Documentos Vinculados</h3>
    
    <% if @person.documents.any? %>
      <ul class="space-y-3 mb-6 relative">
        <% @person.documents.each do |doc| %>
          <li class="bg-white p-4 border rounded shadow-sm flex items-center justify-between">
            <div>
              <p class="font-semibold"><%= doc.title %></p>
              <p class="text-sm text-gray-500"><%= doc.description %></p>
            </div>
            <% if doc.file.attached? %>
              <%= link_to "Download", rails_blob_path(doc.file, disposition: "attachment"), class: "text-blue-600 hover:underline" %>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-gray-500 italic mb-6">Nenhum documento vinculado.</p>
    <% end %>

    <div class="bg-gray-100 p-4 rounded mb-6">
      <h4 class="font-medium mb-3">Vincular Novo Documento</h4>
      <%= form_with model: DocumentLink.new, url: admin_document_links_path, local: true, class: "flex items-end gap-4" do |f| %>
        <%= f.hidden_field :documentable_type, value: "Person" %>
        <%= f.hidden_field :documentable_id, value: @person.id %>
        <div class="flex-1">
          <%= f.label :document_id, "Selecione o Documento", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.collection_select :document_id, Document.all, :id, :title, { prompt: "Escolha um documento..." }, class: "w-full border-gray-300 rounded shadow-sm py-2 px-3" %>
        </div>
        <%= f.submit "Vincular", class: "bg-yellow-500 hover:bg-yellow-400 text-gray-900 font-medium py-2 px-4 rounded cursor-pointer" %>
      <% end %>
    </div>
  </div>

  <div class="mt-8 flex items-center gap-2">
    <%= link_to "Edit this person", edit_admin_person_path(@person), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
    <%= link_to "Back to people", admin_people_path, class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
    <%= button_to "Destroy this person", [:admin, @person], method: :delete, class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>
