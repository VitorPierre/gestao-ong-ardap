<% content_for :page_title, "Parceiros Institucionais" %>

<div class="flex justify-between items-center mb-6">
  <div>
    <h1 class="text-2xl font-black text-gray-900">Parcerias</h1>
    <p class="text-sm text-gray-500 mt-1">Gestão de empresas parceiras, clínicas e voluntariado institucional</p>
  </div>
  <% if can_write? %>
  <%= link_to "+ Novo Parceiro", new_admin_partner_path, class: "bg-yellow-500 hover:bg-yellow-400 text-gray-900 font-bold py-2.5 px-5 rounded-md shadow transition" %>
<% end %>
</div>

<div class="bg-gray-50 p-4 rounded-lg mb-6 border border-gray-200">
  <%= form_with url: admin_partners_path, method: :get, local: true, class: "flex items-end gap-4 flex-wrap" do |f| %>
    <div>
      <%= f.label :status, "Status Operacional", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :status, Partner.statuses.keys.map { |s| [s.humanize, s] }, { include_blank: "Todos", selected: params[:status] }, class: "rounded-md border-gray-300 shadow-sm py-2 px-3 text-sm min-w-[150px]" %>
    </div>
    <div>
      <%= f.label :type, "Tipo de Parceria", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :type, Partner.partnership_types.keys.map { |t| [t.humanize, t] }, { include_blank: "Todos", selected: params[:type] }, class: "rounded-md border-gray-300 shadow-sm py-2 px-3 text-sm min-w-[150px]" %>
    </div>
    <div class="flex gap-2">
      <%= f.submit "Filtrar", class: "bg-gray-800 hover:bg-gray-900 text-white font-medium py-2 px-4 rounded shadow-sm text-sm cursor-pointer" %>
      <%= link_to "Limpar", admin_partners_path, class: "bg-white hover:bg-gray-50 text-gray-700 font-medium py-2 px-4 rounded border border-gray-300 shadow-sm text-sm" %>
    </div>
  <% end %>
</div>

<% if @partners.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @partners.each do |p| %>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden flex flex-col items-start cursor-pointer hover:border-yellow-400 transition-colors" onclick="window.location='<%= admin_partner_path(p) %>'">
        <div class="p-5 w-full flex-grow relative">
          <!-- Badges -->
          <div class="absolute top-4 right-4 flex flex-col items-end gap-1">
            <% color_status = p.active? ? 'bg-green-100 text-green-800' : (p.inactive? ? 'bg-gray-100 text-gray-800' : 'bg-blue-100 text-blue-800') %>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold tracking-wider uppercase <%= color_status %>">
              <%= p.status.humanize %>
            </span>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] bg-gray-100 text-gray-600 border border-gray-200">
              <%= p.partnership_type.humanize %>
            </span>
          </div>

          <!-- Dados -->
          <h3 class="text-lg font-bold text-gray-900 mb-1 w-3/4"><%= p.name %></h3>
          <p class="text-xs text-gray-500 font-mono mb-4"><%= p.document.presence || "Sem documento" %></p>
          
          <div class="space-y-2 mt-4 border-t pt-4">
            <p class="text-sm text-gray-700 flex items-center">
              <span class="w-5 inline-block opacity-50">👤</span> <%= p.contact_name %></p>
            <p class="text-sm text-gray-700 flex items-center">
              <span class="w-5 inline-block opacity-50">📞</span> <%= p.phone.presence || "—" %></p>
            <p class="text-sm text-gray-700 flex items-center">
              <span class="w-5 inline-block opacity-50">📍</span> <%= [p.city, p.state].select(&:present?).join(" - ").presence || "—" %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="bg-white rounded-lg border border-dashed border-gray-300 p-12 text-center">
    <p class="text-gray-500 text-lg">Nenhum parceiro encontrado.</p>
  </div>
<% end %>
