<% content_for :page_title, "Detalhes do Parceiro" %>

<div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
  <div>
    <h1 class="text-3xl font-black text-gray-900"><%= @partner.name %></h1>
    <p class="text-sm text-gray-500 mt-1">Parceiro <%= @partner.partnership_type.humanize %> - Iniciou em <%= @partner.started_at&.strftime("%B, %Y") %></p>
  </div>
  
  <div class="flex items-center gap-3">
    <%= link_to "← Voltar", admin_partners_path, class: "text-gray-600 hover:text-gray-900 font-medium text-sm" %>
    <% if can_write? %><%= link_to "Editar", edit_admin_partner_path(@partner), class: "bg-gray-100 hover:bg-gray-200 text-gray-800 py-2 px-4 rounded font-medium shadow-sm" %><% end %>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  <!-- Coluna 1: Info (1/3) -->
  <div class="md:col-span-1 space-y-6">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5">
      <h3 class="font-bold text-gray-900 mb-4 border-b pb-2">Informações de Contato</h3>
      <dl class="space-y-3 text-sm">
        <div><dt class="text-xs text-gray-500 font-semibold uppercase">Contato Comercial</dt><dd class="text-gray-900 font-medium"><%= @partner.contact_name %></dd></div>
        <div><dt class="text-xs text-gray-500 font-semibold uppercase">Documento</dt><dd class="text-gray-900"><%= @partner.document.presence || "—" %></dd></div>
        <div><dt class="text-xs text-gray-500 font-semibold uppercase">Telefone</dt><dd class="text-gray-900"><%= @partner.phone.presence || "—" %></dd></div>
        <div><dt class="text-xs text-gray-500 font-semibold uppercase">E-mail</dt><dd class="text-gray-900"><%= @partner.email.presence || "—" %></dd></div>
        <div><dt class="text-xs text-gray-500 font-semibold uppercase">Website</dt><dd class="text-gray-900"><%= @partner.website.presence || "—" %></dd></div>
        <div class="pt-2 border-t"><dt class="text-xs text-gray-500 font-semibold uppercase">Endereço</dt>
          <dd class="text-gray-900"><%= @partner.address %><br><%= [@partner.city, @partner.state].select(&:present?).join(" - ") %></dd></div>
      </dl>
      <% if @partner.notes.present? %>
        <div class="mt-4 pt-4 border-t">
          <dt class="text-xs text-gray-500 font-semibold uppercase mb-1">Notas Internas</dt>
          <dd class="text-gray-900 text-sm whitespace-pre-wrap"><%= @partner.notes %></dd>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Coluna 2: Doações (2/3) -->
  <div class="md:col-span-2">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5">
      <div class="flex justify-between items-center mb-4 border-b pb-2">
        <h3 class="font-bold text-gray-900">Histórico de Doações e Aportes</h3>
        <% if can_write? %>
  <%= link_to "+ Nova Doação", new_admin_donation_path(partner_id: @partner.id), class: "bg-yellow-100 hover:bg-yellow-200 text-yellow-800 text-xs font-bold py-1.5 px-3 rounded" %>
<% end %>
      </div>

      <% if @donations.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead>
              <tr>
                <th class="py-2 text-left text-xs font-semibold text-gray-500">Data</th>
                <th class="py-2 text-left text-xs font-semibold text-gray-500">Tipo</th>
                <th class="py-2 text-left text-xs font-semibold text-gray-500">Valor/Descrição</th>
                <th class="py-2 text-left text-xs font-semibold text-gray-500">Status</th>
                <th class="py-2"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% @donations.each do |donation| %>
                <tr class="hover:bg-gray-50">
                  <td class="py-3 text-sm text-gray-900"><%= donation.donated_at.strftime("%d/%m/%Y") %></td>
                  <td class="py-3 text-sm"><span class="px-2 py-0.5 bg-gray-100 text-gray-700 text-xs rounded"><%= donation.donation_type.humanize %></span></td>
                  <td class="py-3 text-sm font-medium text-gray-900">
                    <% if donation.amount.present? %>
                      <p class="text-green-700"><%= number_to_currency(donation.amount, unit: "R$", separator: ",", delimiter: ".") %></p>
                    <% else %>
                      <p class="text-gray-600 truncate max-w-xs"><%= donation.description %></p>
                    <% end %>
                  </td>
                  <td class="py-3 text-sm font-medium text-gray-500"><%= donation.status.humanize %></td>
                  <td class="py-3 text-right text-sm">
                    <%= link_to "Ver", admin_donation_path(donation), class: "text-blue-600 hover:underline" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-gray-500 italic py-6 text-center">Nenhuma doação registrada para esta empresa ou parceiro institucuional. Promova engajamento para alterar esse cenário!</p>
      <% end %>
    </div>
  </div>
</div>
