<% content_for :page_title, "Detalhes da Denúncia" %>

<div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
  <div>
    <div class="flex items-center gap-3 mb-1">
      <h1 class="text-3xl font-black text-gray-900">Denúncia <%= @complaint.protocol_number %></h1>
      <% color_class = @complaint.critical? ? 'bg-red-100 text-red-800 border-red-200' : (@complaint.urgent? ? 'bg-orange-100 text-orange-800 border-orange-200' : 'bg-gray-100 text-gray-800 border-gray-200') %>
      <span class="px-3 py-1 rounded-full text-xs font-bold border uppercase tracking-wider <%= color_class %>">
        <%= @complaint.priority.humanize %>
      </span>
    </div>
    <p class="text-sm text-gray-500">Recebida em <%= l(@complaint.received_at, format: :long) rescue @complaint.received_at %></p>
  </div>
  
  <div class="flex items-center gap-3">
    <%= link_to "← Voltar", admin_complaints_path, class: "text-gray-600 hover:text-gray-900 font-medium text-sm" %>
    <% if can_write? %><%= link_to "Editar", edit_admin_complaint_path(@complaint), class: "bg-gray-100 hover:bg-gray-200 text-gray-800 py-2 px-4 rounded font-medium shadow-sm" %><% end %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Coluna Principal: Detalhes -->
  <div class="lg:col-span-2 space-y-6">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <h3 class="text-lg font-bold text-gray-900 mb-4 border-b pb-2">Informações Iniciais</h3>
      
      <div class="mb-4">
        <p class="text-sm font-medium text-gray-500">Descrição da Ocorrência</p>
        <p class="text-gray-900 mt-1 whitespace-pre-wrap"><%= @complaint.description %></p>
      </div>

      <div class="grid grid-cols-2 gap-4 mt-6">
        <div>
          <p class="text-sm font-medium text-gray-500">Categoria</p>
          <p class="text-gray-900"><%= @complaint.category.humanize %></p>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-500">Status Atual</p>
          <p class="font-semibold text-blue-700"><%= @complaint.status.humanize %></p>
        </div>
      </div>
    </div>

    <!-- Localização -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <h3 class="text-lg font-bold text-gray-900 mb-4 border-b pb-2">Localização</h3>
      <div class="grid grid-cols-1 gap-4">
        <div>
          <p class="text-sm font-medium text-gray-500">Endereço</p>
          <p class="text-gray-900"><%= @complaint.location_address.presence || "Não informado" %></p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-sm font-medium text-gray-500">Cidade</p>
            <p class="text-gray-900"><%= @complaint.location_city.presence || "Não informado" %></p>
          </div>
          <div>
            <p class="text-sm font-medium text-gray-500">Referência</p>
            <p class="text-gray-900"><%= @complaint.location_reference.presence || "Nenhuma" %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Animal Vinculado -->
    <% if @complaint.animal_id.present? %>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 border-l-4 border-l-yellow-500">
        <h3 class="text-lg font-bold text-gray-900 mb-2">Animal Resgatado</h3>
        <p class="text-gray-600 mb-3">Esta denúncia resultou no resgate do seguinte animal:</p>
        <%= link_to admin_animal_path(@complaint.animal_id), class: "inline-block bg-gray-50 hover:bg-gray-100 border border-gray-200 rounded p-3 text-blue-700 font-medium" do %>
          🐾 <%= @complaint.animal.name %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Coluna Lateral: Responsáveis e Timeline -->
  <div class="space-y-6">
    <!-- Denunciante e Equipe -->
    <div class="bg-gray-50 rounded-lg shadow-sm border border-gray-200 p-5">
      <h3 class="font-bold text-gray-900 mb-3 border-b border-gray-200 pb-2">Contatos e Equipe</h3>
      
      <div class="mb-4">
        <p class="text-xs font-semibold text-gray-500 uppercase">Equipe Responsável</p>
        <p class="text-sm font-medium text-gray-900 mt-1"><%= @complaint.assigned_to.presence || "Ainda não atribuído" %></p>
      </div>
      
      <div>
        <p class="text-xs font-semibold text-gray-500 uppercase">Denunciante</p>
        <% if @complaint.anonymous? %>
          <div class="inline-flex items-center gap-1 mt-1 bg-yellow-100 text-yellow-800 text-xs px-2 py-1 rounded font-bold">
            <span class="text-lg">🕵️</span> Denúncia Anônima
          </div>
        <% else %>
          <p class="text-sm font-medium text-gray-900 mt-1"><%= @complaint.complainant_name %></p>
          <p class="text-sm text-gray-600"><%= @complaint.complainant_phone %></p>
        <% end %>
      </div>
      
      <% if @complaint.notes.present? %>
        <div class="mt-4 pt-3 border-t border-dashed border-gray-300">
          <p class="text-xs font-semibold text-gray-500 uppercase mb-1">Notas Ocultas</p>
          <p class="text-xs text-gray-700 blur-[2px] hover:blur-none transition-all duration-300 cursor-help"><%= @complaint.notes %></p>
        </div>
      <% end %>
    </div>

    <!-- Histórico de Atualizações -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5">
      <h3 class="font-bold text-gray-900 mb-4">Atualizações</h3>
      
      <!-- Formulário Inline para Nova Atualização -->
      <div class="bg-gray-50 p-4 rounded mb-6 border border-gray-200">
        <%= form_with model: [:admin, @complaint, @new_update], class: "space-y-3" do |f| %>
          <div>
            <%= f.label :description, "Nova Informação", class: "block text-xs font-semibold text-gray-600 mb-1" %>
            <%= f.text_area :description, rows: 2, required: true, class: "w-full text-sm rounded border-gray-300 shadow-sm focus:border-yellow-500 focus:ring-yellow-500" %>
          </div>
          <div>
            <%= f.label :status_changed_to, "Mudar Status para (Opcional)", class: "block text-xs font-semibold text-gray-600 mb-1" %>
            <%= f.select :status_changed_to, Complaint.statuses.keys.map { |s| [s.humanize, Complaint.statuses[s]] }, { include_blank: "Manter status atual" }, class: "w-full text-sm rounded border-gray-300 shadow-sm focus:border-yellow-500 focus:ring-yellow-500" %>
          </div>
          <%= f.submit "Adicionar Atualização", class: "w-full bg-yellow-500 hover:bg-yellow-400 text-gray-900 text-sm font-bold py-2 px-4 rounded shadow-sm cursor-pointer" %>
        <% end %>
      </div>

      <!-- Timeline -->
      <div class="space-y-6 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-gray-300 before:to-transparent pt-2">
        <% @complaint_updates.each do |cu| %>
          <div class="relative flex items-start">
            <div class="absolute left-0 mt-1 md:left-1/2 md:-ml-2 bg-yellow-500 border-4 border-white h-4 w-4 rounded-full shadow z-10"></div>
            <div class="ml-8 md:ml-0 md:w-1/2 md:pr-8 md:text-right">
              <%# Divisão da esquerda (apenas pra layout grid flex, não usado como esquerda/direita pois vou manter lista linear) %>
              <%# Correção: Lista linear é melhor %>
            </div>
          </div>
        <% end %>
        
        <%# Re-escrita do Timeline simples %>
        <div class="relative border-l-2 border-gray-200 ml-3 pl-5 space-y-6">
          <% if @complaint_updates.any? %>
            <% @complaint_updates.each do |upd| %>
              <div class="relative">
                <!-- Dot -->
                <div class="absolute w-3 h-3 bg-gray-300 rounded-full -left-[1.65rem] top-1.5 border-2 border-white"></div>
                
                <p class="text-xs text-gray-500 mb-0.5"><%= time_ago_in_words(upd.created_at) %> atrás por <span class="font-medium"><%= upd.author %></span></p>
                <div class="bg-white border rounded p-3 shadow-sm text-sm text-gray-800">
                  <%= upd.description %>
                  <% if upd.status_changed_to.present? %>
                    <% status_key = Complaint.statuses.key(upd.status_changed_to) %>
                    <div class="mt-2 text-xs font-semibold text-blue-700 bg-blue-50 inline-block px-2 py-1 rounded">
                      Status alterado para: <%= status_key&.humanize || upd.status_changed_to %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% else %>
            <p class="text-xs text-gray-500 italic ml-2">Nenhuma atualização registrada.</p>
          <% end %>
        </div>
      </div>
      
    </div>
  </div>
</div>
