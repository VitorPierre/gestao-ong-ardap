<% content_for :page_title, "Editar Denúncia" %>

<div class="mb-6 flex justify-between items-end">
  <div>
    <h1 class="text-2xl font-black text-gray-900">Editar Denúncia</h1>
    <p class="text-gray-500 mt-1 font-mono text-sm"><%= @complaint.protocol_number %></p>
  </div>
  <%= link_to "← Ver Protocolo Completo", admin_complaint_path(@complaint), class: "text-sm text-gray-500 hover:text-gray-700" %>
</div>

<%= render "form", complaint: @complaint %>
