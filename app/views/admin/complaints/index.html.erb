<% content_for :page_title, "Denúncias" %>

<div class="flex justify-between items-center mb-6">
  <div>
    <h1 class="text-2xl font-black text-gray-900">Denúncias</h1>
    <p class="text-sm text-gray-500 mt-1">Gerenciamento de suspeitas e ocorrências</p>
  </div>
  <% if can_write? %>
  <%= link_to "+ Nova Denúncia", new_admin_complaint_path, class: "bg-yellow-500 hover:bg-yellow-400 text-gray-900 font-bold py-2.5 px-5 rounded-md shadow transition" %>
<% end %>
</div>

<div class="bg-gray-50 p-4 rounded-lg mb-6 border border-gray-200">
  <%= form_with url: admin_complaints_path, method: :get, local: true, class: "flex items-end gap-4 flex-wrap" do |f| %>
    <div>
      <%= f.label :status, "Status", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :status, Complaint.statuses.keys.map { |s| [s.humanize, s] }, { include_blank: "Todos os Status", selected: params[:status] }, class: "rounded-md border-gray-300 shadow-sm py-2 px-3 text-sm min-w-[150px]" %>
    </div>
    <div>
      <%= f.label :category, "Categoria", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :category, Complaint.categories.keys.map { |c| [c.humanize, c] }, { include_blank: "Todas as Categorias", selected: params[:category] }, class: "rounded-md border-gray-300 shadow-sm py-2 px-3 text-sm min-w-[150px]" %>
    </div>
    <div class="flex gap-2">
      <%= f.submit "Filtrar", class: "bg-gray-800 hover:bg-gray-900 text-white font-medium py-2 px-4 rounded shadow-sm text-sm cursor-pointer" %>
      <%= link_to "Limpar", admin_complaints_path, class: "bg-white hover:bg-gray-50 text-gray-700 font-medium py-2 px-4 rounded border border-gray-300 shadow-sm text-sm" %>
    </div>
  <% end %>
</div>

<% if @complaints.any? %>
  <div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Protocolo</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Data</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Categoria</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Prioridade</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Status</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Responsável</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @complaints.each do |c| %>
            <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location='<%= admin_complaint_path(c) %>'">
              <td class="px-4 py-3 text-sm font-bold text-gray-900"><%= c.protocol_number %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= l(c.received_at, format: :short) rescue c.received_at %></td>
              <td class="px-4 py-3 text-sm text-gray-700">
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
                  <%= c.category.humanize %>
                </span>
              </td>
              <td class="px-4 py-3 text-sm text-gray-700">
                <% color_class = c.critical? ? 'bg-red-100 text-red-800' : (c.urgent? ? 'bg-orange-100 text-orange-800' : 'bg-gray-100 text-gray-600') %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= color_class %>">
                  <%= c.priority.humanize %>
                </span>
              </td>
              <td class="px-4 py-3 text-sm text-gray-700"><%= c.status.humanize %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= c.assigned_to.presence || "—" %></td>
              <td class="px-4 py-3 text-right text-sm font-medium">
                <%= link_to "Detalhes", admin_complaint_path(c), class: "text-blue-600 hover:text-blue-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <div class="bg-white rounded-lg border border-dashed border-gray-300 p-12 text-center">
    <p class="text-gray-500 text-lg">Nenhuma denúncia encontrada com os filtros atuais.</p>
  </div>
<% end %>
