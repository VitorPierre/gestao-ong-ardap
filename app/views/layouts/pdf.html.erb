<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>
  html, body {
    margin: 0;
    padding: 0;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 14px;
    line-height: 1.5;
    color: #333;
  }
  .container {
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
    padding: 20px 40px;
  }
  .header {
    text-align: center;
    border-bottom: 2px solid #fbbf24;
    padding-bottom: 20px;
    margin-bottom: 30px;
  }
  .header h1 {
    margin: 0 0 5px 0;
    font-size: 24px;
    font-weight: bold;
    color: #111827;
  }
  .header p {
    margin: 0;
    font-size: 12px;
    color: #6b7280;
  }
  .footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 10px;
    color: #9ca3af;
    border-top: 1px solid #e5e7eb;
    padding-top: 10px;
    margin-bottom: 10px;
  }
  .content {
    margin-bottom: 150px;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 20px;
  }
  th, td {
    padding: 8px 12px;
    border: 1px solid #e5e7eb;
    text-align: left;
  }
  th {
    background-color: #f9fafb;
    font-weight: bold;
    color: #374151;
  }
  .signature-box {
    margin-top: 80px;
    width: 100%;
    display: flex;
    justify-content: space-between;
  }
  .signature-line {
    width: 45%;
    border-top: 1px solid #111827;
    text-align: center;
    padding-top: 5px;
    font-size: 14px;
    font-weight: bold;
  }
</style>
</head>
<body>

  <div class="header">
    <h1>ARDAP - Associação de Resgate</h1>
    <p>Documento Oficial Gerado por Sistema | CNPJ: 12.345.678/0001-90</p>
  </div>

  <div class="container content">
    <%= yield %>
  </div>

  <div class="footer">
    <p>Este documento é parte do Sistema Administrativo Oficial ONG ARDAP.</p>
    <% if @document && @document.signed? && @document.document_signature.present? %>
      <div style="font-size: 10px; line-height: 1.2; text-align: left; margin-top: 10px; border-top: 1px dashed #9ca3af; padding-top: 5px;">
        <% @document.signature_stamp.each do |line| %>
          <%= line %><br>
        <% end %>
      </div>
    <% end %>
  </div>

</body>
</html>
